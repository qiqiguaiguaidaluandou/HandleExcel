# --- LLM ---
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# --- 数据目录 ---
# 容器内路径（docker-compose 把宿主 backend/data/ 挂到此处）
DATA_DIR=/data
# 上面三个可以不改，留默认即可；也可独立覆盖
# UPLOAD_DIR=/data/uploads
# OUTPUT_DIR=/data/outputs
# DB_PATH=/data/db.sqlite3
# TMP_DIR=/data/tmp

# 宿主 daemon 视角的数据目录绝对路径（兄弟容器模式必需）
# docker-compose 会自动设置；本机裸跑（非容器化）可不填
# HOST_DATA_DIR=/abs/path/to/HandleExcel/backend/data

# --- CORS：多个用逗号分隔 ---
# 用 docker compose 部署时，这一行会被 docker-compose.yml 里的 environment 覆盖
# 只有裸跑（本机 uvicorn）时才会被用到
ALLOWED_ORIGINS=http://172.10.42.142:3001

# --- 执行器（Docker 沙箱）---
EXECUTOR_IMAGE=handleexcel-executor:latest
EXECUTOR_MEMORY=1g
EXECUTOR_CPUS=1
EXECUTOR_TIMEOUT=60
EXECUTOR_PIDS_LIMIT=128

# --- 样本脱敏：发给 LLM 的前 5 行是否替换为伪造数据（默认开启，保护真实数据不外发）---
ANONYMIZE_SAMPLES=true

# --- 执行失败后自动把 traceback 回传 LLM 重试的次数（0 表示关闭自愈循环）---
EXEC_AUTO_RETRY=2
